\documentclass[11pt]{article}

% --------------------------------------------------
% Page geometry
% --------------------------------------------------
\usepackage[
  letterpaper,
  margin=0.20in,
  headheight=48pt,
  headsep=0.4in,
  footskip=3.5in,
  includehead,
  includefoot
]{geometry}


% --------------------------------------------------
% Fonts & encoding
% --------------------------------------------------
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lastpage}
\usepackage{lmodern}

% --------------------------------------------------
% Math packages (common set)
% --------------------------------------------------
\usepackage{amsmath}
\usepackage{amssymb}
\usepackage{amsthm}
\usepackage{mathtools}
\usepackage{physics}
\usepackage{siunitx}
%\usepackage{draftwatermark}

% --------------------------------------------------
% Graphics & diagrams
% --------------------------------------------------
\usepackage{graphicx}
\usepackage{tikz}
\usepackage{circuitikz}
\usepackage{xcolor}

% --------------------------------------------------
% Header / Footer
% --------------------------------------------------
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{} % clear defaults

% --------------------------------------------------
% User-defined metadata (EDIT THESE)
% --------------------------------------------------
\newcommand{\NoteTitle}{Note Title}
\newcommand{\StudentName}{Raleigh Littles}
\newcommand{\StudentID}{\#0123456789}
\newcommand{\ClassName}{Course Title}
\newcommand{\NoteDate}{\today}

% --------------------------------------------------
% Header layout
% --------------------------------------------------
\fancyhead[L]{%
  \Huge{\NoteTitle}
}

\fancyhead[R]{%
  \begin{tabular}{r}
    \StudentName \\
    ID: \StudentID \\
    \ClassName \\
    \NoteDate \\
    Page \thepage \hspace{1pt} of \hspace{1pt} \pageref{LastPage}
  \end{tabular}
}

% --------------------------------------------------
% Footer layout
% --------------------------------------------------
\fancyfoot[L]{%
  \textbf{\NoteTitle} --- \StudentName
}

\fancyfoot[C]{%
  Page \thepage
}

\fancyfoot[R]{%
  % Reserved space for a 300x300 px image (~3.1in x 3.1in)
  \begin{minipage}[c][1in][c]{1in}
    %\centering
    % Uncomment to include an image:
    \includegraphics[width=0.75in,height=0.75in,keepaspectratio]{AssignmentTemplate-footer.png}
    \vspace{15pt}
  \end{minipage}
}

% --------------------------------------------------
% Rule lines
% --------------------------------------------------
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}

% --------------------------------------------------
% Document
% --------------------------------------------------
\begin{document}

\section{Your section name here}

\pagebreak

\end{document}
